  "classification_rules": {
    "coastal_exposure": {
      "enabled": true,
      "priority": 1,
      "description": "Coastal classification - highest priority for exposed coastal terrain",
      "conditions": {
        "near_coast_distance_km": 2.0,
        "requires_direct_exposure": true,
        "excludes_dense_urban_cities": true
      }
    },
    "dense_urban": {
      "enabled": true,
      "priority": 2,
      "description": "Dense urban areas - check before other rules",
      "conditions": {
        "applicable_to_terrain": ["II", "IIIb"],
        "dense_urban_threshold": 0.35,
        "total_urban_threshold": 0.65,
        "analysis_radius_km": 2.0
      }
    },
    "bocage_characteristics": {
      "enabled": true,
      "priority": 3,
      "description": "Urban areas with bocage characteristics - downgrade to IIIa",
